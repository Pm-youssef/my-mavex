# متغيرات البيئة الأساسية للموقع
NODE_ENV=production
SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# قاعدة البيانات (استخدم PostgreSQL من Neon/Supabase/Render)
DATABASE_URL=postgresql://username:password@host:port/dbname?schema=public

# كلمات المرور والمفاتيح (استخدم قيم قوية وعشوائية)
ADMIN_PASSWORD=YourStrongAdminPassword123!
ADMIN_JWT_SECRET=your-random-jwt-secret-for-admin-change-me-12345
USER_JWT_SECRET=your-random-jwt-secret-for-users-change-me-67890

# بوابة الدفع Paymob (اختياري - لو مش هتستخدمها، اتركها فارغة)
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=your-integration-id
PAYMOB_IFRAME_ID=your-iframe-id

# تحليلات (اختياري)
NEXT_PUBLIC_GA_ID=GA-MEASUREMENT-ID
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js

# مكافحة السبام (اختياري - لو مش هتستخدمها، اتركها فارغة)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# تسجيل دخول اجتماعي (اختياري - لو مش هتستخدمها، اتركها فارغة)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
